#!/bin/sh
# Arch-dispatching wrapper for the bundled dharma binaries. Points the CLI at
# the plugin's bundled config (PAT + default workspace, baked in at install
# time) unless the caller already set XDG_CONFIG_HOME.
set -eu

root="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)"

os="$(uname -s | tr '[:upper:]' '[:lower:]')"
arch="$(uname -m)"
case "$arch" in
  aarch64|arm64) arch=arm64 ;;
  x86_64|amd64) arch=amd64 ;;
  *) echo "dharma wrapper: unsupported architecture: $arch" >&2; exit 1 ;;
esac

bin="$root/bin/dharma-$os-$arch"
if [ ! -f "$bin" ]; then
  echo "dharma wrapper: no binary for $os/$arch (bundled: $(ls "$root/bin" | grep '^dharma-' | tr '\n' ' '))" >&2
  exit 1
fi

# Exec bits can get lost when plugin files are synced into the Cowork VM.
# Heal to a per-user path; reuse it across invocations when it already matches
# (the copy is ~10MB), and build via mktemp + atomic rename so concurrent
# invocations never exec a partial copy.
if [ ! -x "$bin" ]; then
  healed="${TMPDIR:-/tmp}/dharma-healed-$(id -u)"
  if ! { [ -x "$healed" ] && [ -O "$healed" ] && cmp -s "$bin" "$healed"; }; then
    tmp="$(mktemp "${TMPDIR:-/tmp}/dharma-heal.XXXXXX")"
    cp "$bin" "$tmp" && chmod 755 "$tmp" && mv -f "$tmp" "$healed"
  fi
  bin="$healed"
fi

XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$root/config}"
export XDG_CONFIG_HOME
exec "$bin" "$@"
